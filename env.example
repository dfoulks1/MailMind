# MailMind — environment configuration
# Copy to .env and fill in your values.
# NEVER commit .env to version control.

# ── OAuth 2.0 (required) ──────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → Desktop app.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_TOKEN_FILE=token.json

# ── Gmail API ─────────────────────────────────────────────────────────────────
GMAIL_DEFAULT_QUERY=-category:trash newer_than:1d
GMAIL_MAX_RESULTS=200
GMAIL_MAX_BODY_CHARS=6000
GMAIL_API_TIMEOUT=30.0

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=120.0
OLLAMA_NUM_CTX=4096
OLLAMA_TEMPERATURE=0.2

# ── RAG store ─────────────────────────────────────────────────────────────────
RAG_DB_PATH=mailmind.db
RAG_CHUNK_SIZE=400
RAG_CHUNK_OVERLAP=40

# ── Scheduler ────────────────────────────────────────────────────────────────
# Cron expression (takes precedence over INGEST_INTERVAL_MINUTES if set).
# Examples:
#   "0 */6 * * *"   — every 6 hours
#   "0 7 * * *"     — every day at 07:00
#   "*/30 * * * *"  — every 30 minutes
INGEST_CRON=0 */6 * * *
# Fallback interval in minutes when INGEST_CRON is not set.
INGEST_INTERVAL_MINUTES=360
# Set to false to disable background scheduling (useful for one-shot query mode).
SCHEDULER_ENABLED=true

# ── HTTP service ──────────────────────────────────────────────────────────────
SERVICE_HOST=127.0.0.1
SERVICE_PORT=8765
SERVICE_LOG_LEVEL=info
