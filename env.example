# Gmail Analyzer — environment configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
#
# SECURITY: never commit .env to version control.
# Add .env and token.json to your .gitignore.

# ── OAuth 2.0 credentials ─────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → Desktop app.
# See docs/README.md for step-by-step setup instructions.

OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=your-client-secret

# Path where the OAuth access/refresh token is cached after first login.
# Delete this file to force re-authorization.
OAUTH_TOKEN_FILE=token.json

# ── Gmail MCP server ──────────────────────────────────────────────────────
# Google's official hosted endpoint — only change this if Google updates it.

GMAIL_MCP_URL=https://gmailmcp.googleapis.com/mcp/v1

# ── Ollama ────────────────────────────────────────────────────────────────

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# How long to wait for an Ollama response (seconds).
# Increase for slower hardware or larger models.
OLLAMA_TIMEOUT=120.0

# Context window size (tokens). llama3.2:1b default is 4096.
OLLAMA_NUM_CTX=4096

# Sampling temperature. Lower = more factual, higher = more creative.
OLLAMA_TEMPERATURE=0.2

# ── Misc ──────────────────────────────────────────────────────────────────

# Maximum number of threads to fetch per search query.
# Gmail REST API caps at 500 per page; use multiple pages for more.
MAX_RESULTS=500

# Maximum characters of email body sent to Ollama per message.
# Increase if threads are being truncated; decrease to save context budget.
MAX_BODY_CHARS=6000

# HTTP timeout for calls to the Gmail MCP server (seconds).
MCP_TIMEOUT=30.0
